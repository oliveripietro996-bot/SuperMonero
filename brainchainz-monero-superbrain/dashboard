<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SuperMonero P2Pool Mini</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    body { background-color: #0a0a0a; color: #e5e7eb; }
    .monero-green { color: #00c853; }
  </style>
</head>
<body class="min-h-screen p-6">
  <div class="max-w-7xl mx-auto">
    <header class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-4xl font-bold monero-green flex items-center gap-3">
          <i class="fas fa-cube"></i> SuperMonero P2Pool Mini
        </h1>
        <p class="text-gray-400">Mining decentralizzato • P2Pool Mini</p>
      </div>
      <div class="text-right">
        <div id="status" class="inline-flex items-center gap-2 px-4 py-2 bg-green-900/30 text-green-400 rounded-full text-sm font-medium">
          <div class="w-3 h-3 bg-green-400 rounded-full animate-pulse"></div>
          MINING ATTIVO
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Hashrate Card -->
      <div class="bg-zinc-900 rounded-2xl p-6 border border-zinc-800">
        <div class="flex justify-between items-start">
          <div>
            <p class="text-gray-400 text-sm">Hashrate Attuale</p>
            <h2 id="hashrate" class="text-5xl font-bold monero-green mt-2">0 KH/s</h2>
          </div>
          <i class="fas fa-chart-line text-4xl text-green-500/30"></i>
        </div>
      </div>

      <!-- Shares / Efficiency -->
      <div class="bg-zinc-900 rounded-2xl p-6 border border-zinc-800">
        <p class="text-gray-400 text-sm">Shares (ultimi 10m)</p>
        <h2 id="shares" class="text-5xl font-bold text-white mt-2">0</h2>
        <p id="efficiency" class="text-green-400 text-sm mt-1">Efficienza: --</p>
      </div>

      <!-- Wallet -->
      <div class="bg-zinc-900 rounded-2xl p-6 border border-zinc-800">
        <p class="text-gray-400 text-sm">Wallet</p>
        <p id="wallet" class="font-mono text-xs break-all mt-2 text-gray-300">Inserisci il tuo wallet dall'app</p>
      </div>
    </div>

    <!-- Grafico Hasrate -->
    <div class="mt-8 bg-zinc-900 rounded-3xl p-6 border border-zinc-800">
      <h3 class="text-lg font-semibold mb-4">Hashrate in tempo reale</h3>
      <canvas id="hashrateChart" height="120"></canvas>
    </div>

    <div class="mt-6 text-center text-xs text-gray-500">
      SuperMonero P2Pool Mini v1.2.0 • Nessun devfee • Completamente decentralizzato
    </div>
  </div>

  <script>
    // Chart.js setup
    const ctx = document.getElementById('hashrateChart');
    const hashrateChart = new Chart(ctx, {
      type: 'line',
      data: { labels: [], datasets: [{ label: 'Hashrate (KH/s)', data: [], borderColor: '#00c853', tension: 0.4 }] },
      options: { scales: { y: { beginAtZero: true } }, plugins: { legend: { display: false } } }
    });

    // Simulazione dati (da sostituire con fetch reali da API in futuro)
    let hashrateHistory = [];
    setInterval(() => {
      const current = Math.floor(Math.random() * 15) + 5; // simulazione
      document.getElementById('hashrate').textContent = current + " KH/s";
      hashrateHistory.push(current);
      if (hashrateHistory.length > 20) hashrateHistory.shift();
      hashrateChart.data.labels = hashrateHistory.map((_, i) => i + "s");
      hashrateChart.data.datasets[0].data = hashrateHistory;
      hashrateChart.update();
    }, 3000);
  </script>
</body>
</html>
